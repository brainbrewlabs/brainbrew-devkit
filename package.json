{
  "name": "brainbrew-devkit",
  "version": "1.0.0",
  "description": "AI-powered development toolkit — customizable agent chains, modular skills, and automated workflow orchestration",
  "type": "module",
  "bin": {
    "brainbrew": "./dist/cli.js"
  },
  "files": [
    "dist",
    "plugin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vitepress": "^1.6.0"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
