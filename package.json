{
  "name": "brainbrew-devkit",
  "version": "1.0.0",
  "description": "AI-powered development toolkit — customizable agent chains, modular skills, and automated workflow orchestration",
  "type": "module",
  "bin": {
    "brainbrew": "./dist/cli.js"
  },
  "files": [
    "dist",
    "plugin"
  ],
  "scripts": {
    "build": "tsup",
